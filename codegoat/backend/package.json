    "@fastify/sensible": "^6.0.0",
    "@langchain/core": "^1.2.3",
    "@langchain/langgraph": "^1.4.8",
    "@langchain/openai": "^1.5.5",
    "deepagents": "^1.11.1",
    "fastify": "^5.0.0",
    "fastify-cli": "^7.4.1",
    "fastify-plugin": "^5.0.0",
    "langchain": "^1.5.3",
    "openai": "^6.48.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
