  "version": "1.0.0",
  "description": "This project was bootstrapped with Fastify-CLI.",
  "main": "dist/app.js",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/**/*.test.ts",
    "start": "fastify start -l info dist/app.js",
